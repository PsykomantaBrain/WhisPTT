{
  "name": "whisptt",
  "version": "0.1.0",
  "description": "Push-to-talk voice dictation for Steam Deck using the OpenAI Whisper API.",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf dist && rollup -c",
    "watch": "rollup -c -w"
  },
  "keywords": ["decky", "steam-deck", "whisper", "dictation", "voice", "ptt"],
  "license": "BSD-3-Clause",
  "dependencies": {
    "@decky/api": "^1.1.2",
    "@decky/ui": "^4.9.0",
    "react-icons": "^5.4.0"
  },
  "devDependencies": {
    "@decky/rollup": "^1.0.1",
    "@types/react": "18.3.3",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.30.1",
    "shx": "^0.3.4",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
